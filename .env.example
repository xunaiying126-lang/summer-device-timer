# 不配置 Firebase 时，应用会自动使用本机 localStorage 模式。
# 如需公网多设备实时同步，请创建 Firebase Web App + Firestore，
# 然后在部署平台填入这些 VITE_ 环境变量。
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# 同一个家庭/同一份数据使用同一个 ID。
# 建议使用不容易猜到的字符串，例如 xu-family-2026-随机后缀。
VITE_HOUSEHOLD_ID=xu-family-summer-2026
